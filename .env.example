# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ==============================================================================
# Hướng dẫn: Copy file này thành .env hoặc .env.docker và điền các thông tin thực tế.
# ==============================================================================

# 1. Đường dẫn tới mô hình ONNX AI
# Ví dụ khi chạy trong Docker container: /app/core_backend/models/ramp_XUnet_256.onnx
MODEL_PATH=./core_backend/models/ramp_XUnet_256.onnx

# 2. Cấu hình kết nối cơ sở dữ liệu PostGIS (lưu ý điền password theo password database của bạn)
DB_CONN=PG:host=localhost port=5432 dbname=gis_db user=postgres password=your_secure_password_here

# 3. Tên bảng PostGIS lưu trữ kết quả đa giác công trình (Building Footprints)
DB_TABLE=buildings_polygon

# 4. Cấu hình cổng dịch vụ (Web API & Frontend)
PORT_BACKEND=3001
PORT_FRONTEND=3000
